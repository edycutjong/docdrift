{
  "schema": 2,
  "permissions": [
    "tools.invoke",
    "storage.read",
    "storage.write",
    "chat.append_artifact",
    "chat.write_message",
    "llm.complete",
    "ui.svg"
  ],
  "required_executas": [
    {
      "tool_id": "tool-dev-docdrift",
      "min_version": "0.3.0",
      "version": "latest"
    }
  ],
  "optional_executas": [],
  "system_prompt_addendum": "You are DocDrift, a code-to-docs auditor. Instruct the user to use open_app_view('drift_viewer') when reviewing specific code changes. Use agent sessions for multi-turn drift analysis. Stream patches using R2 links. Generate architecture diagrams with image/generate.",
  "user_message_prefix_template": "[DocDrift] {user_message}",
  "tags": ["documentation", "testing", "developer-tools", "ai", "security", "embeddings", "rag"],
  "ui": {
    "bundle": {
      "format": "static-spa",
      "entry": "index.html",
      "external_origins": []
    },
    "views": [
      {
        "name": "main",
        "title": "DocDrift Workspace",
        "default": true,
        "entry": "index.html",
        "min_size": { "w": 640, "h": 500 },
        "default_size": { "w": 1100, "h": 800 },
        "max_size": { "w": 1920, "h": 1200 },
        "resizable": true,
        "movable": true,
        "single_instance": true,
        "summary_template": "DocDrift Workspace: {scanned_path}"
      },
      {
        "name": "drift_viewer",
        "title": "Drift Viewer",
        "entry": "index.html#/drift",
        "min_size": { "w": 640, "h": 480 },
        "default_size": { "w": 900, "h": 700 },
        "resizable": true,
        "movable": true
      }
    ],
    "host_api": {
      "tools": ["required:*"],
      "llm": ["complete", "embed"],
      "image": ["generate", "edit"],
      "agent": { "session": { "auto": true } },
      "chat": ["write_message", "append_artifact"],
      "storage": ["get", "set", "delete", "list"],
      "window": ["set_title", "open_view", "close"],
      "upload": ["inline", "negotiate", "confirm"]
    },
    "csp_overrides": {
      "img-src": ["https:"]
    },
    "state_merge": "last_writer_wins"
  },
  "dev": {
    "fixtures": ["fixtures/*.jsonl"],
    "seed_storage": {},
    "user_id": 1
  }
}
